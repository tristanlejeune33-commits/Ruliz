# ============================================================
# RULIZ — DEV LOCAL
# Copie ce fichier vers .env.local (pas .env, pour ne pas être
# committed) et remplis les valeurs depuis Railway → Variables.
#
# Comment récupérer chaque valeur :
#   Railway dashboard → projet RULIZ → service "Ruliz" → onglet Variables
#   → bouton "Raw Editor" en haut à droite → copie tout
# ============================================================

# --- Database ---
# IMPORTANT : utilise DATABASE_PUBLIC_URL et NON DATABASE_URL.
# DATABASE_URL Railway pointe sur postgres.railway.internal qui n'est
# joignable QUE depuis Railway. La PUBLIC_URL passe par viaduct.proxy
# et marche depuis ton PC.
#
# Sur Railway : projet → service Postgres → Variables → DATABASE_PUBLIC_URL
# (si pas dispo, va sur l'onglet "Networking" du service Postgres et
# clique "Generate TCP Proxy Domain")
DATABASE_URL=postgresql://postgres:PASSWORD@viaduct.proxy.rlwy.net:PORT/railway

# --- Auth (même valeur que Railway) ---
BETTER_AUTH_SECRET=copie_depuis_railway_le_meme_secret
BETTER_AUTH_URL=http://localhost:3000

# --- Anthropic (même clé que Railway) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Cloudflare R2 (mêmes valeurs que Railway) ---
R2_ACCOUNT_ID=893ce38542575ee20e0c5afa74e1a699
R2_ACCESS_KEY_ID=420e...ad99
R2_SECRET_ACCESS_KEY=cee4...cc28
R2_BUCKET_NAME=ruliz-media
R2_PUBLIC_URL=https://pub-0c5b826a396b4a9381f261f9c2a40739.r2.dev

# --- Stripe (test keys, mêmes que Railway si tu en as) ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# --- Resend (optionnel en dev) ---
RESEND_API_KEY=

# --- Redis (LAISSE VIDE EN DEV) ---
# L'app marche sans Redis, juste un peu plus lente sur la carte publique.
# Surtout que ton Redis Railway est down de toute façon.
# REDIS_URL=

# --- Inngest (LAISSE VIDE EN DEV) ---
# En local, le fallback `after()` fait tourner les traductions en background
# directement dans Next.js. Plus simple à debugger.
# INNGEST_EVENT_KEY=
# INNGEST_SIGNING_KEY=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
