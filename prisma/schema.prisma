// Ruliz — Prisma schema (port de docs/schema.sql)
// Convention : tables snake_case en DB, modèles PascalCase en TS, fields camelCase via @map.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH (Better-Auth — tables séparées du domaine métier)
// ============================================

model AuthUser {
  id            String   @id
  email         String   @unique
  emailVerified Boolean  @default(false) @map("email_verified")
  name          String?
  image         String?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  // Lien vers l'utilisateur métier (1-1 optionnel).
  userId Int?  @unique @map("user_id")
  user   User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Champ shadow pour Better-Auth (peut écrire dessus si plugin admin réactivé,
  // ou si une vieille session/cache demande la colonne). Le rôle métier
  // canonique reste sur `users.role`.
  role String? @default("user")

  sessions Session[]
  accounts Account[]

  @@map("auth_user")
}

model Session {
  id        String   @id
  userId    String   @map("user_id")
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  user      AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_session")
}

model Account {
  id                    String    @id
  userId                String    @map("user_id")
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")
  user                  AuthUser  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("auth_account")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@map("auth_verification")
}

// ============================================
// DOMAINE MÉTIER (port de docs/schema.sql)
// ============================================

enum UserRole {
  admin
  client
  team

  @@map("user_role")
}

enum UserStatut {
  actif
  suspendu
  archive
  demo_terminee

  @@map("user_statut")
}

enum Plan {
  freemium
  pro
  premium

  @@map("plan")
}

enum CategorieMode {
  liste
  grille
  carrousel

  @@map("categorie_mode")
}

model User {
  id               Int        @id @default(autoincrement())
  email            String     @unique @db.VarChar(255)
  passwordHash     String     @default("") @map("password_hash") // legacy column ; auth via Better-Auth
  prenom           String?    @db.VarChar(100)
  nom              String?    @db.VarChar(100)
  telephone        String?    @db.VarChar(20)
  adresse          String?
  codePostal       String?    @map("code_postal") @db.VarChar(10)
  ville            String?    @db.VarChar(100)
  pays             String?    @default("France") @db.VarChar(100)
  /**
   * Code ISO du pays (FR, IT, etc.) — sert à pré-remplir la langue native
   * du futur restaurant à sa création.
   */
  countryCode      String?    @default("FR") @map("country_code") @db.VarChar(2)
  /**
   * Langue native déduite du pays au signup. Pré-remplit Restaurant.langueNative.
   */
  langueNative     String?    @default("fr") @map("langue_native") @db.VarChar(2)
  role             UserRole   @default(client)
  statut           UserStatut @default(actif)
  demoActive       Boolean    @default(false) @map("demo_active")
  stripeCustomerId String?    @unique @map("stripe_customer_id") @db.VarChar(255)
  createdAt        DateTime   @default(now()) @map("created_at") @db.Timestamptz()
  lastLoginAt      DateTime?  @map("last_login_at") @db.Timestamptz()

  /// === Onboarding tour (bulle guidée première connexion) ===
  /// Étape courante (0 = pas démarré, 1..6 = en cours, 6 = terminé).
  onboardingStep        Int       @default(0)     @map("onboarding_step")
  /// True si l'utilisateur a complété les 6 étapes
  onboardingCompleted   Boolean   @default(false) @map("onboarding_completed")
  /// True si l'utilisateur a cliqué "Passer le tour" — on ne réaffiche plus
  onboardingSkipped     Boolean   @default(false) @map("onboarding_skipped")
  /// Timestamp 1er affichage de la bulle
  onboardingStartedAt   DateTime? @map("onboarding_started_at") @db.Timestamptz()
  /// Timestamp fin du tour (étape 6 validée)
  onboardingCompletedAt DateTime? @map("onboarding_completed_at") @db.Timestamptz()
  /// True quand l'user a scanné son propre QR depuis l'étape 6 (KPI aha moment)
  onboardingSelfScanned Boolean   @default(false) @map("onboarding_self_scanned")

  authUser           AuthUser?
  restaurants        Restaurant[]
  teamOf             TeamMember[]       @relation("OwnerTeam")
  teamMemberOf       TeamMember[]       @relation("MemberOf")
  logs               Log[]
  boutiqueCommandes  BoutiqueCommande[]

  @@index([email], map: "idx_users_email")
  @@index([statut], map: "idx_users_statut")
  @@map("users")
}

model TeamMember {
  id           BigInt   @id @default(autoincrement())
  userId       Int      @map("user_id")
  memberUserId Int      @map("member_user_id")
  roleMember   String   @default("editor") @map("role_member") @db.VarChar(50)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  owner  User @relation("OwnerTeam", fields: [userId], references: [id], onDelete: Cascade)
  member User @relation("MemberOf", fields: [memberUserId], references: [id], onDelete: Cascade)

  @@map("team_members")
}

model Restaurant {
  id                       BigInt    @id @default(autoincrement())
  userId                   Int       @map("user_id")
  nom                      String    @db.VarChar(255)
  email                    String?   @db.VarChar(255)
  telephone                String?   @db.VarChar(20)
  adresse                  String?
  codePostal               String?   @map("code_postal") @db.VarChar(10)
  ville                    String?   @db.VarChar(100)
  pays                     String?   @db.VarChar(100)
  plan                     Plan      @default(freemium)
  statut                   String    @default("actif") @db.VarChar(20)
  stripeSubscriptionId     String?   @unique @map("stripe_subscription_id") @db.VarChar(255)
  stripePriceId            String?   @map("stripe_price_id") @db.VarChar(255)
  stripeSubscriptionStatus String?   @map("stripe_subscription_status") @db.VarChar(50)
  stripeCurrentPeriodEnd   DateTime? @map("stripe_current_period_end") @db.Timestamptz()
  /** Plan offert par l'admin (bypass Stripe) — la date d'expiration de la
      période gratuite Pro/Premium accordée. Si > now → le plan reste actif
      même sans Stripe sub. À l'expiration, le code peut revert automatiquement
      en freemium (ou laisser l'admin gérer). null = aucun cadeau actif. */
  planOffertExpiresAt      DateTime? @map("plan_offert_expires_at") @db.Timestamptz()
  /** Plan offert par qui (admin user id) — pour l'audit / traçabilité. */
  planOffertByUserId       Int?      @map("plan_offert_by_user_id")
  logoUrl                  String?   @map("logo_url")
  banniereUrl              String?   @map("banniere_url")
  description              String?
  deviseDefault            String?   @default("€") @map("devise_default") @db.VarChar(5)
  /**
   * Langue native du restaurant (la langue dans laquelle le restaurateur saisit sa carte).
   * Tout le système de traduction part de cette langue vers les autres.
   * Default "fr" pour rétrocompat avec l'existant. ISO 639-1.
   */
  langueNative             String    @default("fr") @map("langue_native") @db.VarChar(2)
  // ----- Horaires de service personnalisables (par resto) -----
  // Permet de customiser les créneaux "lunch" / "dinner" / "happy_hour"
  // utilisés par le filtrage des catégories sur la carte publique.
  // Format HH:MM (ex: "11:30"). Défauts standards si NULL.
  lunchStart               String?   @default("11:30") @map("lunch_start") @db.VarChar(5)
  lunchEnd                 String?   @default("15:00") @map("lunch_end") @db.VarChar(5)
  dinnerStart              String?   @default("18:30") @map("dinner_start") @db.VarChar(5)
  dinnerEnd                String?   @default("23:00") @map("dinner_end") @db.VarChar(5)
  happyHourStart           String?   @default("18:00") @map("happy_hour_start") @db.VarChar(5)
  happyHourEnd             String?   @default("19:00") @map("happy_hour_end") @db.VarChar(5)
  // ----- Personnalisation visuelle de la carte publique -----
  theme                    String?   @default("light") @db.VarChar(10) // light | dark
  fontStyle                String?   @default("editorial") @map("font_style") @db.VarChar(20) // modern | editorial | elegant
  couleurPrimaire          String?   @default("#1F2937") @map("couleur_primaire") @db.VarChar(7)
  couleurSecondaire        String?   @map("couleur_secondaire") @db.VarChar(7)
  couleurFond              String?   @map("couleur_fond") @db.VarChar(7)
  couleurTexteTitre        String?   @map("couleur_texte_titre") @db.VarChar(7)
  couleurCategorie         String?   @map("couleur_categorie") @db.VarChar(7)
  // ----- Réseaux sociaux -----
  facebookUrl              String?   @map("facebook_url")
  instagramUrl             String?   @map("instagram_url")
  tiktokUrl                String?   @map("tiktok_url")
  siteWeb                  String?   @map("site_web")
  googleReviewUrl          String?   @map("google_review_url")
  createdAt                DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  user              User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  qrcodes           Qrcode[]
  categories        Categorie[]
  jeux              Jeu[]
  popups            Popup[]
  baseClients       BaseClient[]
  boutiqueCommandes BoutiqueCommande[]

  @@index([userId], map: "idx_restaurants_user")
  @@map("restaurants")
}

model Qrcode {
  id           BigInt    @id @default(autoincrement())
  restaurantId BigInt    @map("restaurant_id")
  codeUnique   String    @unique @map("code_unique") @db.VarChar(20)
  pngUrl       String?   @map("png_url")
  statut       String    @default("actif") @db.VarChar(20)
  assignedAt   DateTime? @map("assigned_at") @db.Timestamptz()
  scanTotal    BigInt    @default(0) @map("scan_total")
  scanMois     BigInt    @default(0) @map("scan_mois")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId], map: "idx_qrcodes_restaurant")
  @@index([codeUnique], map: "idx_qrcodes_code")
  @@map("qrcodes")
}

model Categorie {
  id            BigInt        @id @default(autoincrement())
  restaurantId  BigInt        @map("restaurant_id")
  parentId      BigInt?       @map("parent_id")
  titre         String        @db.VarChar(255)
  icone         String?       @db.VarChar(50)
  position      Int           @default(0)
  affiche       Boolean       @default(true)
  modeAffichage CategorieMode @default(liste) @map("mode_affichage")
  /**
   * Créneau d'affichage : "always" = visible 24/7 (défaut), "lunch" = 11h30-15h,
   * "dinner" = 18h30-23h, "happy_hour" = 18h-19h, "custom" = utilise les champs
   * scheduleStart/scheduleEnd pour des horaires perso. Toutes les catégories
   * existantes sont en "always" par défaut.
   */
  scheduleType  String        @default("always") @map("schedule_type") @db.VarChar(20)
  /** Heure de début si scheduleType = "custom" — format HH:MM (ex: "11:30") */
  scheduleStart String?       @map("schedule_start") @db.VarChar(5)
  /** Heure de fin si scheduleType = "custom" — format HH:MM */
  scheduleEnd   String?       @map("schedule_end") @db.VarChar(5)
  /**
   * Jours de la semaine où la catégorie est visible.
   * "1234567" = tous les jours (Mon-Sun, ISO weekday).
   * "12345" = Lun-Ven uniquement. "67" = week-end.
   */
  scheduleDays  String        @default("1234567") @map("schedule_days") @db.VarChar(7)
  /**
   * Couleur custom du bouton accordéon (override le theme global du resto).
   * Format hex #RRGGBB. NULL = utilise theme.primary.
   */
  couleur       String?       @db.VarChar(7)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamptz()

  restaurant   Restaurant             @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  parent       Categorie?             @relation("CategorieParent", fields: [parentId], references: [id], onDelete: Cascade)
  children     Categorie[]            @relation("CategorieParent")
  produits     Produit[]
  translations CategorieTranslation[]

  @@index([restaurantId, position], map: "idx_categories_restaurant")
  @@index([parentId], map: "idx_categories_parent")
  @@map("categories")
}

model Produit {
  id                  BigInt   @id @default(autoincrement())
  categorieId         BigInt   @map("categorie_id")
  titre               String   @db.VarChar(255)
  description         String?
  imageUrl            String?  @map("image_url")
  prix                Decimal? @db.Decimal(10, 2)
  devise              String?  @default("€") @db.VarChar(5)
  descriptionPrix     String?  @map("description_prix")
  /** Variantes de prix pour les produits multi-volumes (bière demi/pinte,
      vin verre/bouteille, planche petite/grande, etc.).
      Format JSON : [{"label":"Demi","prix":3.50},{"label":"Pinte","prix":6.50}]
      Si null ou tableau vide → on utilise le champ `prix` simple (rétrocompat).
      Si non vide → le champ `prix` est masqué côté affichage public au profit
      de la liste des variantes. */
  prixVariantes       Json?    @map("prix_variantes")
  position            Int      @default(0)
  statut              String   @default("affiche") @db.VarChar(20)
  estNouveau          Boolean  @default(false) @map("est_nouveau")
  /** Compteur cumulé de clics (ouvertures du modal détail) */
  clicCount           Int      @default(0) @map("clic_count")
  origine             String?  @db.VarChar(2)
  titreRemarque       String?  @map("titre_remarque") @db.VarChar(255)
  descriptionRemarque String?  @map("description_remarque")
  /**
   * Créneau d'affichage du PRODUIT lui-même (override de la catégorie).
   * "always" (défaut) = visible quand la catégorie est visible.
   * Sinon : "lunch", "dinner", "happy_hour", "custom" — les mêmes presets
   * que les catégories (cf. src/lib/schedule.ts).
   */
  scheduleType        String   @default("always") @map("schedule_type") @db.VarChar(20)
  scheduleStart       String?  @map("schedule_start") @db.VarChar(5)
  scheduleEnd         String?  @map("schedule_end") @db.VarChar(5)
  scheduleDays        String   @default("1234567") @map("schedule_days") @db.VarChar(7)
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt           DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  categorie     Categorie            @relation(fields: [categorieId], references: [id], onDelete: Cascade)
  vignettes     ProduitVignette[]
  allergenes    ProduitAllergene[]
  suggestionsIn ProduitSuggestion[]  @relation("ProduitSrc")
  suggestionsOf ProduitSuggestion[]  @relation("ProduitDst")
  translations  ProduitTranslation[]

  @@index([categorieId, position], map: "idx_produits_categorie_pos")
  @@map("produits")
}

model Vignette {
  id      Int     @id @default(autoincrement())
  code    String  @unique @db.VarChar(30)
  labelFr String  @map("label_fr") @db.VarChar(100)
  icone   String? @db.VarChar(50)

  produits ProduitVignette[]

  @@map("vignettes")
}

model ProduitVignette {
  produitId  BigInt @map("produit_id")
  vignetteId Int    @map("vignette_id")

  produit  Produit  @relation(fields: [produitId], references: [id], onDelete: Cascade)
  vignette Vignette @relation(fields: [vignetteId], references: [id], onDelete: Cascade)

  @@id([produitId, vignetteId])
  @@map("produit_vignettes")
}

model Allergene {
  id      Int    @id @default(autoincrement())
  code    String @unique @db.VarChar(30)
  labelFr String @map("label_fr") @db.VarChar(100)

  produits ProduitAllergene[]

  @@map("allergenes")
}

model ProduitAllergene {
  produitId   BigInt @map("produit_id")
  allergeneId Int    @map("allergene_id")

  produit   Produit   @relation(fields: [produitId], references: [id], onDelete: Cascade)
  allergene Allergene @relation(fields: [allergeneId], references: [id], onDelete: Cascade)

  @@id([produitId, allergeneId])
  @@map("produit_allergenes")
}

model ProduitSuggestion {
  produitId    BigInt @map("produit_id")
  suggestionId BigInt @map("suggestion_id")
  position     Int    @default(0)

  produit    Produit @relation("ProduitSrc", fields: [produitId], references: [id], onDelete: Cascade)
  suggestion Produit @relation("ProduitDst", fields: [suggestionId], references: [id], onDelete: Cascade)

  @@id([produitId, suggestionId])
  @@index([produitId, position], map: "idx_suggestions_produit")
  @@map("produit_suggestions")
}

model ProduitTranslation {
  produitId           BigInt   @map("produit_id")
  lang                String   @db.VarChar(2)
  titre               String?
  description         String?
  descriptionPrix     String?  @map("description_prix")
  titreRemarque       String?  @map("titre_remarque")
  descriptionRemarque String?  @map("description_remarque")
  origine             String?
  source              String   @default("anthropic") @db.VarChar(20)
  translatedAt        DateTime @default(now()) @map("translated_at") @db.Timestamptz()

  produit Produit @relation(fields: [produitId], references: [id], onDelete: Cascade)

  @@id([produitId, lang])
  @@map("produit_translations")
}

model CategorieTranslation {
  categorieId BigInt  @map("categorie_id")
  lang        String  @db.VarChar(2)
  titre       String?

  categorie Categorie @relation(fields: [categorieId], references: [id], onDelete: Cascade)

  @@id([categorieId, lang])
  @@map("categorie_translations")
}

// NOTE: La table `scans` est partitionnée mensuellement en SQL natif Postgres.
// Prisma ne supporte pas le partitioning déclaratif → on déclare le modèle ici
// et la commande PARTITION BY est ajoutée via une migration SQL custom.
model Scan {
  id           BigInt   @default(autoincrement())
  qrcodeId     BigInt?  @map("qrcode_id")
  restaurantId BigInt?  @map("restaurant_id")
  lang         String?  @db.VarChar(2)
  userAgent    String?  @map("user_agent")
  pays         String?  @db.VarChar(2)
  scannedAt    DateTime @default(now()) @map("scanned_at") @db.Timestamptz()

  @@id([id, scannedAt])
  @@index([restaurantId, scannedAt(sort: Desc)], map: "idx_scans_restaurant_date")
  @@map("scans")
}

model Jeu {
  id           BigInt   @id @default(autoincrement())
  restaurantId BigInt   @map("restaurant_id")
  nom          String?  @db.VarChar(255)
  actif        Boolean  @default(true)
  /** Si true, le modal s'ouvre automatiquement à l'ouverture de la carte. */
  autoPopup    Boolean  @default(false) @map("auto_popup")
  /** Délai en secondes avant l'auto-popup (ex: 3 = 3s après le load). */
  autoPopupDelaySec Int  @default(3) @map("auto_popup_delay_sec")
  /** Date/heure de début (null = actif dès maintenant) */
  dateDebut    DateTime? @map("date_debut") @db.Timestamptz()
  /** Date/heure de fin (null = pas de fin programmée) */
  dateFin      DateTime? @map("date_fin") @db.Timestamptz()
  configJson   Json?    @map("config_json")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  restaurant     Restaurant         @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  participations JeuParticipation[]

  @@map("jeux")
}

model JeuParticipation {
  id             BigInt    @id @default(autoincrement())
  jeuId          BigInt    @map("jeu_id")
  email          String?   @db.VarChar(255)
  prenom         String?   @db.VarChar(100)
  nom            String?   @db.VarChar(100)
  /** Date de naissance saisie par le joueur (texte libre côté formulaire). */
  naissance      String?   @db.VarChar(20)
  telephone      String?   @db.VarChar(20)
  /** Action sociale validée : "facebook" | "instagram" | "google_review" */
  actionSociale  String?   @map("action_sociale") @db.VarChar(20)
  lotGagne       String?   @map("lot_gagne") @db.VarChar(255)
  /** IP du joueur — utile pour limiter le spam */
  ip             String?   @db.VarChar(45)
  participatedAt DateTime  @default(now()) @map("participated_at") @db.Timestamptz()

  jeu Jeu @relation(fields: [jeuId], references: [id], onDelete: Cascade)

  @@index([jeuId, participatedAt(sort: Desc)], map: "idx_participations_jeu")
  @@index([email], map: "idx_participations_email")
  @@map("jeu_participations")
}

model Popup {
  id           BigInt    @id @default(autoincrement())
  restaurantId BigInt    @map("restaurant_id")
  titre        String?   @db.VarChar(255)
  description  String?
  imageUrl     String?   @map("image_url")
  ctaLabel     String?   @map("cta_label") @db.VarChar(100)
  ctaUrl       String?   @map("cta_url")
  dateDebut    DateTime? @map("date_debut") @db.Timestamptz()
  dateFin      DateTime? @map("date_fin") @db.Timestamptz()
  /** Planning par jour de la semaine : bitmap 7 bits, bit 0 = dimanche,
      bit 1 = lundi, …, bit 6 = samedi. null = tous les jours.
      Ex: mardi+jeudi = 0b0010100 = 20. mardi+vendredi = 0b0100100 = 36. */
  joursActifs  Int?      @map("jours_actifs")
  /** Plage horaire d'affichage dans la journée. Format "HH:MM" (24h).
      null = toute la journée. Si défini, les 2 doivent être présents. */
  heureDebut   String?   @map("heure_debut") @db.VarChar(5)
  heureFin     String?   @map("heure_fin")   @db.VarChar(5)
  actif        Boolean   @default(true)

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@map("popups")
}

model BaseClient {
  id           BigInt   @id @default(autoincrement())
  restaurantId BigInt   @map("restaurant_id")
  email        String?  @db.VarChar(255)
  telephone    String?  @db.VarChar(20)
  prenom       String?  @db.VarChar(100)
  /** Nom de famille — pour les tags SMS {nom} */
  nom          String?  @db.VarChar(100)
  /** Date d'anniversaire — pour automatisation SMS anniversaire */
  anniversaire DateTime? @db.Date
  source       String?  @db.VarChar(50)
  /** RGPD : true si le client a accepté de recevoir des SMS marketing */
  optInSms     Boolean  @default(true) @map("opt_in_sms")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz()

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@index([restaurantId], map: "idx_baseclients_restaurant")
  @@map("base_clients")
}

model Log {
  id        BigInt   @id @default(autoincrement())
  userId    Int?     @map("user_id")
  action    String?  @db.VarChar(50)
  details   Json?
  ip        String?  @db.VarChar(45)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz()

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)], map: "idx_logs_user")
  @@map("logs")
}

// ============================================================================
// BOUTIQUE QR — catalogue de produits que les clients restaurateurs peuvent
// commander depuis leur dashboard (sets de table imprimés, supports vitrine,
// stickers ronds, présentoirs A6, etc.). Géré 100% par l'admin via /admin/boutique.
// ============================================================================

enum BoutiqueProduitStatut {
  brouillon
  publie
  archive
}

model BoutiqueProduit {
  id            BigInt                @id @default(autoincrement())
  /** Slug unique pour les URL (ex: "set-de-table-100x") */
  slug          String                @unique @db.VarChar(120)
  nom           String                @db.VarChar(255)
  description   String?               @db.Text
  prixCentimes  Int                   @map("prix_centimes")
  devise        String                @default("EUR") @db.VarChar(3)
  /** URL R2 de la photo principale */
  imageUrl      String?               @map("image_url") @db.VarChar(500)
  /** Catégorie texte libre (ex: "Sets de table", "Stickers", "Vitrine") */
  categorie     String?               @db.VarChar(100)
  position      Int                   @default(0)
  statut        BoutiqueProduitStatut @default(brouillon)
  /** Stock maximum (capacité totale). null = illimité. Le stock utilisé
      est calculé dynamiquement à partir de la somme des items des
      commandes non annulées (cf. server/admin/boutique/queries.ts). */
  stockMax      Int?                  @map("stock_max")
  /** JSON des features bullet (ex: ["100 unités", "Format A4", "Pelliculage mat"]) */
  featuresJson  Json?                 @map("features_json")
  /** ID Stripe Product (synchro auto à chaque create/update). null si Stripe
      pas configuré ou sync non encore effectuée. */
  stripeProductId String?             @map("stripe_product_id") @db.VarChar(100)
  /** ID Stripe Price (one-shot, pas récurrent). Utilisé par Checkout Session.
      Recréé à chaque changement de prix (Stripe ne permet pas de modifier un
      Price existant — on archive l'ancien et on crée un nouveau). */
  stripePriceId   String?             @map("stripe_price_id") @db.VarChar(100)
  createdAt     DateTime              @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt     DateTime              @updatedAt @map("updated_at") @db.Timestamptz()

  commandeItems BoutiqueCommandeItem[]

  @@index([statut, position], map: "idx_boutique_produits_statut_position")
  @@map("boutique_produits")
}

enum BoutiqueCommandeStatut {
  en_attente
  en_preparation
  expediee
  livree
  annulee
}

model BoutiqueCommande {
  id              BigInt                 @id @default(autoincrement())
  /** User qui a commandé (depuis son dashboard) */
  userId          Int                    @map("user_id")
  /** Restaurant auquel la commande est rattachée (optionnel — pour stats) */
  restaurantId    BigInt?                @map("restaurant_id")
  /** Total en centimes = somme des items.totalCentimes (snapshot post-création) */
  totalCentimes   Int                    @map("total_centimes")
  devise          String                 @default("EUR") @db.VarChar(3)
  /** Adresse de livraison (snapshot) */
  livraisonNom         String?           @map("livraison_nom") @db.VarChar(255)
  livraisonAdresse     String?           @map("livraison_adresse") @db.Text
  livraisonCodePostal  String?           @map("livraison_code_postal") @db.VarChar(10)
  livraisonVille       String?           @map("livraison_ville") @db.VarChar(100)
  livraisonPays        String?           @default("France") @map("livraison_pays") @db.VarChar(100)
  livraisonTelephone   String?           @map("livraison_telephone") @db.VarChar(20)
  /** Notes libres du client (ex: "merci de mettre mon logo en or") */
  notesClient     String?                @map("notes_client") @db.Text
  /** Notes internes admin (ex: "facture envoyée le 12/05") */
  notesAdmin      String?                @map("notes_admin") @db.Text
  statut          BoutiqueCommandeStatut @default(en_attente)
  /** Stripe Checkout Session ID (cs_test_... / cs_live_...). Présent si le
      client a démarré un paiement en ligne. */
  stripeCheckoutSessionId String?        @map("stripe_checkout_session_id") @db.VarChar(255)
  /** Stripe Payment Intent ID (pi_...). Set par le webhook quand le paiement
      réussit. */
  stripePaymentIntentId   String?        @map("stripe_payment_intent_id") @db.VarChar(100)
  /** Date du paiement réussi (set par le webhook). null = pas encore payé. */
  paidAt                  DateTime?      @map("paid_at") @db.Timestamptz()
  createdAt       DateTime               @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime               @updatedAt @map("updated_at") @db.Timestamptz()

  user       User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant?            @relation(fields: [restaurantId], references: [id], onDelete: SetNull)
  items      BoutiqueCommandeItem[]

  @@index([userId, createdAt(sort: Desc)], map: "idx_boutique_commandes_user")
  @@index([statut, createdAt(sort: Desc)], map: "idx_boutique_commandes_statut")
  @@map("boutique_commandes")
}

/**
 * Ligne de commande : 1 commande peut contenir N items, chaque item =
 * 1 produit × quantité, avec snapshot du prix au moment de la commande.
 */
model BoutiqueCommandeItem {
  id            BigInt   @id @default(autoincrement())
  commandeId    BigInt   @map("commande_id")
  produitId     BigInt   @map("produit_id")
  /** Snapshot du nom du produit (au cas où le produit serait renommé/supprimé après) */
  produitNom    String   @map("produit_nom") @db.VarChar(255)
  quantite      Int      @default(1)
  /** Snapshot du prix unitaire en centimes */
  prixUnitaire  Int      @map("prix_unitaire")
  /** Total ligne = prixUnitaire × quantite */
  totalCentimes Int      @map("total_centimes")
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz()

  commande BoutiqueCommande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  BoutiqueProduit  @relation(fields: [produitId], references: [id], onDelete: Restrict)

  @@index([commandeId], map: "idx_boutique_commande_items_commande")
  @@index([produitId], map: "idx_boutique_commande_items_produit")
  @@map("boutique_commande_items")
}

// ============================================================
// SMS MARKETING — système de crédits
// ============================================================
// Modèle : Tristan achète des SMS en gros sur Brevo (~0.03€/SMS),
// les revend en packs à ses clients restaurateurs avec marge.
// 1 seule BREVO_API_KEY côté serveur, jamais exposée aux clients.
// Tracking par restaurant : balance, achats, envois.

/**
 * Solde de crédits SMS d'un restaurant.
 * 1 ligne = 1 restaurant (unique). Décrémenté à chaque envoi, incrémenté
 * à chaque achat de pack via Stripe Checkout.
 */
model SmsBalance {
  id            BigInt   @id @default(autoincrement())
  restaurantId  BigInt   @unique @map("restaurant_id")
  /** Solde courant en tokens SMS (1 token = 1 segment GSM = 160 chars max) */
  balance       Int      @default(0)
  /** Total cumulé jamais reset (pour stats admin) */
  totalAcquired Int      @default(0) @map("total_acquired")
  totalSpent    Int      @default(0) @map("total_spent")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([restaurantId], map: "idx_sms_balance_resto")
  @@map("sms_balance")
}

/**
 * Historique des achats de packs SMS (via Stripe Checkout one-shot).
 */
model SmsCreditPurchase {
  id                BigInt   @id @default(autoincrement())
  restaurantId      BigInt   @map("restaurant_id")
  /** Nombre de SMS tokens achetés (ex: 100, 500, 1000, 5000) */
  packSize          Int      @map("pack_size")
  /** Prix payé en centimes (€) */
  pricePaidCentimes Int      @map("price_paid_centimes")
  /** ID session Stripe Checkout (idempotence webhook) */
  stripeSessionId   String?  @unique @map("stripe_session_id") @db.VarChar(255)
  /** "pending" / "paid" / "refunded" / "failed" */
  status            String   @default("pending") @db.VarChar(20)
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz()
  paidAt            DateTime? @map("paid_at") @db.Timestamptz()

  @@index([restaurantId], map: "idx_sms_purchase_resto")
  @@index([status], map: "idx_sms_purchase_status")
  @@map("sms_credit_purchases")
}

/**
 * Historique des envois (1 ligne = 1 SMS individuel envoyé via Brevo).
 * Permet de re-tracer, calculer coût, exporter pour facturation.
 */
model SmsMessage {
  id            BigInt   @id @default(autoincrement())
  restaurantId  BigInt   @map("restaurant_id")
  /** Numéro destinataire au format international (33612345678) */
  recipient     String   @db.VarChar(20)
  /** Contenu final envoyé (après remplacement des tags) */
  content       String   @db.Text
  /** Nombre de segments (1 si ≤160 chars, sinon 2+) = tokens consommés */
  segments      Int      @default(1)
  /** "sent" / "failed" / "skipped" */
  status        String   @default("pending") @db.VarChar(20)
  /** Référence Brevo retournée par l'API */
  brevoRef      String?  @map("brevo_ref") @db.VarChar(255)
  /** Si campagne : lien vers la campagne parente */
  campaignId    BigInt?  @map("campaign_id")
  /** Si automatisation : type d'auto qui a déclenché (anniversaire, etc.) */
  triggerType   String?  @map("trigger_type") @db.VarChar(50)
  /** Si erreur Brevo, message */
  errorMessage  String?  @map("error_message") @db.Text
  sentAt        DateTime @default(now()) @map("sent_at") @db.Timestamptz()

  @@index([restaurantId], map: "idx_sms_message_resto")
  @@index([campaignId], map: "idx_sms_message_campaign")
  @@index([sentAt], map: "idx_sms_message_sent_at")
  @@map("sms_messages")
}

/**
 * Campagne SMS (blast groupé) — 1 envoi à N destinataires avec le même
 * template (qui peut contenir des tags personnalisés {prenom}, {nom}…).
 */
model SmsCampaign {
  id              BigInt   @id @default(autoincrement())
  restaurantId    BigInt   @map("restaurant_id")
  /** Titre de la campagne pour retrouver dans l'historique */
  title           String   @db.VarChar(255)
  /** Template avec tags ({prenom}, {nom}, {resto}…) avant remplacement */
  messageTemplate String   @map("message_template") @db.Text
  /** Filtre destinataires : "all", "roulette", "manual", ou JSON custom */
  targetFilter    String   @default("all") @map("target_filter") @db.VarChar(100)
  /** Compteurs finaux après envoi */
  totalSent       Int      @default(0) @map("total_sent")
  totalFailed     Int      @default(0) @map("total_failed")
  totalSkipped    Int      @default(0) @map("total_skipped")
  /** Tokens dépensés (= total_sent × segments_moyens) */
  tokensSpent     Int      @default(0) @map("tokens_spent")
  status          String   @default("draft") @db.VarChar(20)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  sentAt          DateTime? @map("sent_at") @db.Timestamptz()

  @@index([restaurantId], map: "idx_sms_campaign_resto")
  @@map("sms_campaigns")
}

/**
 * Configuration des packs SMS — édité par l'admin global (Tristan).
 * 1 ligne par pack (starter / boost / growth / scale). Si la table est
 * vide, le code retombe sur les valeurs par défaut codées dans
 * src/server/dashboard/sms-packs.ts.
 *
 * Permet à l'admin de changer les prix sans redéploiement.
 */
model SmsPackSetting {
  /** ID logique du pack : "starter" / "boost" / "growth" / "scale" */
  packId        String   @id @map("pack_id") @db.VarChar(20)
  /** Nombre de SMS dans le pack */
  size          Int
  /** Prix en centimes (€) */
  priceCentimes Int      @map("price_centimes")
  /** Libellé visible : "Pack Découverte", "Pack Boost"… */
  label         String   @db.VarChar(100)
  /** Badge optionnel : "Populaire", "Économie"… */
  badge         String?  @db.VarChar(50)
  /** false = pack masqué côté dashboard restos */
  active        Boolean  @default(true)
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@map("sms_pack_settings")
}

/**
 * Automatisation SMS : déclencheur récurrent (anniversaire client,
 * relance post-roulette, etc.). Cron quotidien Inngest fait le scan.
 */
model SmsAutomation {
  id              BigInt   @id @default(autoincrement())
  restaurantId    BigInt   @map("restaurant_id")
  /** "birthday" / "post_roulette" / "anniversary_signup" / etc. */
  triggerType     String   @map("trigger_type") @db.VarChar(50)
  /** Template avec tags */
  messageTemplate String   @map("message_template") @db.Text
  /** Offset en jours : 0 = jour J, 1 = J+1, -7 = J-7 (pour rappel anniv) */
  daysOffset      Int      @default(0) @map("days_offset")
  /** Heure d'envoi 0-23 (default 10h) */
  sendHour        Int      @default(10) @map("send_hour")
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz()
  updatedAt       DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz()

  @@index([restaurantId], map: "idx_sms_auto_resto")
  @@index([triggerType, active], map: "idx_sms_auto_trigger_active")
  @@map("sms_automations")
}
