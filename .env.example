# =============================================
# RULIZ — Environnement
# Copie ce fichier vers .env et remplis les valeurs.
# =============================================

# --- Database (Railway Postgres) ---
DATABASE_URL=postgresql://user:password@localhost:5432/ruliz

# --- Auth (Better-Auth) ---
# Génère un secret de 32+ caractères : `openssl rand -base64 32`
BETTER_AUTH_SECRET=changeme_minimum_32_chars_long_secret_replace_this_string
BETTER_AUTH_URL=http://localhost:3000

# --- Google OAuth (optionnel — bouton "Continuer avec Google") ---
# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorized redirect URI : {BETTER_AUTH_URL}/api/auth/callback/google
# Si absent, le bouton Google n'apparaît pas (login email/password seul).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Anthropic (traduction menus) ---
# Modèle utilisé : claude-haiku-4-5-20251001
ANTHROPIC_API_KEY=sk-ant-...

# --- Google Maps Platform (avis Google sur le mini-site vitrine) ---
# Place Details API renvoie note moyenne + 5 reviews max.
# Google Cloud donne $200/mois gratuit → quasi gratuit à notre échelle
# (50 restos × refresh hebdo ≈ $0.034/mois). Setup :
#   1. console.cloud.google.com → nouveau projet
#   2. Active "Places API" + "Places API (New)"
#   3. Créer une clé API → restrictions optionnelles (HTTP referer pour
#      la sécu de prod)
#   4. Hard-limit billing à $0 dans la console pour éviter toute surprise
GOOGLE_MAPS_API_KEY=AIza...

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_PREMIUM_PRICE_ID=price_...

# --- Cloudflare R2 (storage images) ---
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=ruliz-media
R2_PUBLIC_URL=https://media.ruliz.app

# --- Resend (emails transactionnels) ---
RESEND_API_KEY=re_...

# --- Brevo (SMS marketing — Premium) ---
BREVO_API_KEY=
BREVO_SMS_SENDER=Ruliz

# --- Redis (Railway — cache cartes traduites) ---
REDIS_URL=redis://default:password@localhost:6379

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Sentry (optionnel mais recommandé) ---
# DSN public (côté client + serveur — même DSN, différentes init)
NEXT_PUBLIC_SENTRY_DSN=
# Org + projet pour upload des sourcemaps (CI uniquement)
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
